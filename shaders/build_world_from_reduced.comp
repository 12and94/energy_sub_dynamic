#version 460

layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout(push_constant) uniform PushConstants {
    uint numVerts;
    uint numTets;
    float invDt2;
    float mu;
    float lam;
    float alpha;
    float groundY;
    float groundK;
    uint useGround;
    uint numReduced;
} pc;

layout(std430, binding = 0) readonly buffer BasisBuf {
    float basis[];
};

layout(std430, binding = 1) readonly buffer ReducedInBuf {
    float reducedIn[];
};

layout(std430, binding = 2) writeonly buffer WorldOutBuf {
    vec4 worldOut[];
};

void main() {
    uint v = gl_GlobalInvocationID.x;
    if (v >= pc.numVerts) {
        return;
    }

    float ux = 0.0;
    float uy = 0.0;
    float uz = 0.0;

    uint r = pc.numReduced;
    uint row0 = (3u * v + 0u) * r;
    uint row1 = (3u * v + 1u) * r;
    uint row2 = (3u * v + 2u) * r;
    for (uint k = 0u; k < r; ++k) {
        float qk = reducedIn[k];
        ux += basis[row0 + k] * qk;
        uy += basis[row1 + k] * qk;
        uz += basis[row2 + k] * qk;
    }

    worldOut[v] = vec4(ux, uy, uz, 0.0);
}
